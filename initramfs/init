#!/bin/busybox sh

/bin/busybox --install -s /bin

mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t configfs configfs /sys/kernel/config
mount -t debugfs debugfs /sys/kernel/debug 2>/dev/null

hostname r11t-mainline
echo 8 > /proc/sys/kernel/printk

# USB console first — keep this independent of display bring-up.
G=/sys/kernel/config/usb_gadget/r11t
mkdir -p "$G/strings/0x409" "$G/configs/c.1/strings/0x409"
echo 0x18d1 > "$G/idVendor"
echo 0xd001 > "$G/idProduct"
echo r11t-mainline > "$G/strings/0x409/serialnumber"
echo OPPO > "$G/strings/0x409/manufacturer"
echo "R11T mainline console" > "$G/strings/0x409/product"
echo "USB serial console" > "$G/configs/c.1/strings/0x409/configuration"
mkdir -p "$G/functions/acm.usb0"
ln -s "$G/functions/acm.usb0" "$G/configs/c.1/acm.usb0"

set -- /sys/class/udc/*
if [ -e "$1" ]; then
	echo "${1##*/}" > "$G/UDC"
fi

# Resolve eMMC by label; mainline may expose mmcblk0 or mmcblk1.
resolve_part() {
	name="$1"
	for d in /dev/block/by-name /dev/disk/by-partlabel /sys/class/block; do
		if [ -e "$d/$name" ]; then
			readlink -f "$d/$name" 2>/dev/null && return 0
		fi
	done
	for b in /sys/class/block/mmcblk*p*; do
		[ -e "$b/uevent" ] || continue
		partname=$(sed -n 's/^PARTNAME=//p' "$b/uevent" 2>/dev/null)
		[ "$partname" = "$name" ] || continue
		echo "/dev/${b##*/}"
		return 0
	done
	return 1
}

mkdir -p /mnt/vendor /mnt/modem /lib/firmware /lib/modules
VENDOR_DEV=""
MODEM_DEV=""
for retry in $(seq 1 100); do
	[ -n "$VENDOR_DEV" ] || VENDOR_DEV=$(resolve_part vendor)
	[ -n "$MODEM_DEV" ] || MODEM_DEV=$(resolve_part modem)
	[ -n "$VENDOR_DEV" ] && [ -n "$MODEM_DEV" ] && break
	sleep 0.1
done
if [ -n "$VENDOR_DEV" ]; then
	mount -t ext4 -o ro "$VENDOR_DEV" /mnt/vendor 2>/dev/null || true
fi
if [ -n "$MODEM_DEV" ]; then
	mount -t vfat -o ro "$MODEM_DEV" /mnt/modem 2>/dev/null || true
fi

# Prefer packaged firmware; fall back to vendor/modem mounts.
printf %s /lib/firmware > /sys/module/firmware_class/parameters/path 2>/dev/null
if [ -d /mnt/vendor/firmware ]; then
	# Extra search path for any missing blobs still only on vendor.
	:
fi
if [ -d /mnt/modem/image ]; then
	ln -sfn /mnt/modem/image /lib/firmware/image 2>/dev/null
	# MSS remoteproc often looks for mba.mbn/modem.mdt at firmware root.
	for f in mba.mbn modem.mdt adsp.mdt; do
		[ -f "/mnt/modem/image/$f" ] && ln -sf "/mnt/modem/image/$f" "/lib/firmware/$f"
	done
	for image in modem adsp; do
		for f in /mnt/modem/image/$image.b*; do
			[ -f "$f" ] || continue
			ln -sf "$f" "/lib/firmware/$(basename "$f")"
		done
	done
fi

insmod /lib/modules/rmi_core.ko 2>/dev/null
insmod /lib/modules/rmi_i2c.ko 2>/dev/null

