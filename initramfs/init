cat > /bin/test_wifi << 'EOF'
#!/bin/busybox sh
export LD_LIBRARY_PATH=/lib:/usr/lib:${LD_LIBRARY_PATH}

echo "=== prepare partitions and firmware ==="
mkdir -p /dev/disk/by-partlabel
for retry in $(seq 1 20); do
	for b in /sys/class/block/mmcblk*p*; do
		[ -e "$b/uevent" ] || continue
		partname=$(sed -n 's/^PARTNAME=//p' "$b/uevent" 2>/dev/null)
		[ -n "$partname" ] || continue
		ln -sfn "/dev/${b##*/}" "/dev/disk/by-partlabel/$partname"
	done
	[ -e /dev/disk/by-partlabel/modem ] && break
	sleep 1
done
mkdir -p /mnt/modem /lib/firmware
if ! mountpoint -q /mnt/modem; then
	mount -t vfat -o ro "$(readlink -f /dev/disk/by-partlabel/modem)" /mnt/modem || exit 1
fi
for f in mba.mbn modem.mdt wlanmdsp.mbn; do
	[ -f "/mnt/modem/image/$f" ] || { echo "missing modem firmware $f"; exit 1; }
	ln -sfn "/mnt/modem/image/$f" "/lib/firmware/$f"
done
ln -sfn /mnt/modem/image /lib/firmware/image
[ -d /mnt/modem/image/modem_pr ] && \
	ln -sfn /mnt/modem/image/modem_pr /lib/firmware/modem_pr
for f in /mnt/modem/image/modem.b*; do
	[ -f "$f" ] && ln -sfn "$f" "/lib/firmware/$(basename "$f")"
done

echo "=== load transport stack ==="
for m in rmtfs_mem libarc4 rfkill cfg80211 mac80211 ath qmi_helpers qrtr qrtr-smd qcom_pdr_msg pdr_interface qcom-r11t-memshare qcom_pd_mapper mdt_loader qcom_pil_info qcom_common qcom_aoss qcom_sysmon ipa2-lite qcom_q6v5 qcom_q6v5_mss; do
	[ -f "/lib/modules/${m}.ko" ] || { echo "missing $m.ko"; continue; }
	insmod "/lib/modules/${m}.ko" 2>/dev/null || true
done

# Coredump mode must be selected before rmtfs -s starts the modem.
for i in $(seq 1 50); do
	for r in /sys/class/remoteproc/remoteproc*; do
		[ -e "$r/name" ] || continue
		case "$(cat "$r/name" 2>/dev/null)" in
		*4080000*|*mss*|*modem*)
			echo enabled > "$r/coredump" 2>/dev/null || true
			echo disabled > "$r/recovery" 2>/dev/null || true
			echo "remoteproc coredump=$(cat "$r/coredump" 2>/dev/null)"
