	/bin/diag-router >/tmp/diag-router.log 2>&1 &
	sleep 1
	echo "diag-router pid=$(pidof diag-router)"
fi

# Publish the modem TFTP service before rmtfs starts MSS.
mkdir -p /tmp /var/lib/tqftpserv
if [ -x /bin/tqftpserv ] && ! pidof tqftpserv >/dev/null 2>&1; then
	/bin/tqftpserv -d >/tmp/tqftpserv.log 2>&1 &
	sleep 1
	echo "tqftpserv pid=$(pidof tqftpserv)"
fi

# Expose modem EFS partitions by label for rmtfs -P.
ls -l /dev/disk/by-partlabel/modemst1 /dev/disk/by-partlabel/modemst2 /dev/qcom_rmtfs_mem1 2>/dev/null || true

# Publish RMTFS before ath10k starts MSS so modem NV/EFS requests can be answered.
mkdir -p /tmp /boot
# Ensure OPPO NV partition aliases used by rmtfs
for pair in "oem_stanvbk:oppostanvbk" "oem_dycnvbk:oppodycnvbk"; do
	label=${pair%%:*}; src=${pair##*:}
	if [ -e "/dev/disk/by-partlabel/$src" ]; then
		target=$(readlink -f "/dev/disk/by-partlabel/$src")
		ln -sfn "$target" "/dev/disk/by-partlabel/$label"
	fi
done
ls -l /dev/disk/by-partlabel/oppostanvbk /dev/disk/by-partlabel/oppodycnvbk /dev/disk/by-partlabel/oem_stanvbk 2>/dev/null || true
if [ -x /bin/rmtfs ]; then
	if ! pidof rmtfs >/dev/null 2>&1; then
		echo "starting rmtfs"
		export LD_LIBRARY_PATH=/lib
		/bin/rmtfs -P -r -v >/tmp/rmtfs.log 2>&1 &
		sleep 1
		echo "rmtfs pid=$(pidof rmtfs)"
		cat /tmp/rmtfs.log 2>/dev/null | tail -n 30
	fi
else
	echo "rmtfs binary missing"
fi

# ath10k must prepare WLAN MSA and its PDR listener before the first MSS boot.
echo "loading ath10k before MSS"
insmod /lib/modules/ath10k_core.ko 2>/dev/null || true
insmod /lib/modules/ath10k_snoc.ko 2>/dev/null || true

if [ -n "${MSS_RPROC:-}" ]; then
	echo start > "$MSS_RPROC/state" 2>/dev/null || true
fi
echo "=== factory WLAN MAC ==="
WLAN_MAC=$(/bin/wifi-mac) || {
	echo "failed to read WLAN MAC from modem DMS"
	exit 1
}
if [ ! -w /sys/module/ath10k_snoc/parameters/mac_addr ]; then
	echo "ath10k_snoc MAC parameter is unavailable"
	exit 1
fi
printf '%s' "$WLAN_MAC" > /sys/module/ath10k_snoc/parameters/mac_addr || exit 1
echo "factory WLAN MAC provisioned: $WLAN_MAC"
sleep 8

for r in /sys/class/remoteproc/remoteproc*; do
	[ -e "$r/name" ] || continue
	name=$(cat "$r/name" 2>/dev/null)
	case "$name" in
	*4080000*|*mss*|*modem*)
		state=$(cat "$r/state" 2>/dev/null)
		echo "remoteproc $name state=$state"
		echo disabled > "$r/recovery" 2>/dev/null || true
		;;
	esac
done
sleep 3

if [ -n "${MSS_RPROC:-}" ] && [ "$(cat "$MSS_RPROC/state" 2>/dev/null)" = "crashed" ]; then
	(
		for i in $(seq 1 300); do
			CORE=$(echo /sys/class/devcoredump/devcd*/data)
			[ -e "$CORE" ] && break
			sleep 0.1
		done
		if [ -e "${CORE:-}" ]; then
			strings -t x -n 12 "$CORE" |
				grep -Eai "assert|fatal|panic|exception|error|ipa_bam|software offset|wlan|qurt|watchdog|dog bite|filename|line [0-9]" |
				tail -n 800 > /tmp/mpss-core-strings.log
		fi
	) &
fi

for retry in $(seq 1 150); do
	[ -e /sys/class/net/wlan0/address ] && break
	sleep 0.1
done
if [ ! -e /sys/class/net/wlan0/address ]; then
	echo "wlan0 did not register"
	exit 1
fi
APPLIED_WLAN_MAC=$(cat /sys/class/net/wlan0/address)
echo "registered WLAN MAC: $APPLIED_WLAN_MAC"
if [ "$APPLIED_WLAN_MAC" != "$WLAN_MAC" ]; then
	echo "WLAN MAC verification failed"
	exit 1
fi

echo "=== remoteproc ==="
for r in /sys/class/remoteproc/remoteproc*; do
	[ -e "$r/name" ] || continue
	printf "%s name=" "${r##*/}"
	cat "$r/name" 2>/dev/null
	printf " state="
	cat "$r/state" 2>/dev/null
	echo
done
echo "=== qrtr ==="
ls /sys/bus/qrtr/devices 2>/dev/null
echo "=== wifi node ==="
ls -l /sys/bus/platform/devices/*18800000* 2>/dev/null || true
echo "=== netdevs ==="
ls /sys/class/net
if [ -e /sys/class/net/wlan0 ] && [ -x /bin/nl80211-scan ]; then
	echo "=== nl80211 scan ==="
	/bin/nl80211-scan wlan0 || true
fi
echo "=== dmesg wifi ==="
dmesg | grep -Ei "ath10k|wcn3990|qmi|qrtr|q6v5|mpss|remoteproc|board_id|chip_id|wlan|firmware|fatal|crash|rmtfs" | tail -n 140
echo "=== rmtfs log ==="
cat /tmp/rmtfs.log 2>/dev/null | tail -n 40
echo "=== tqftpserv log ==="
cat /tmp/tqftpserv.log 2>/dev/null | tail -n 80
echo "=== diag-router log ==="
cat /tmp/diag-router.log 2>/dev/null | tail -n 80
EOF
chmod 0755 /bin/test_wifi

# Make the board's read-only fuel gauge available without a module manager.
for module in bq27xxx_battery bq27xxx_battery_i2c; do
	insmod "/lib/modules/${module}.ko" 2>/dev/null || true
done

# Register LEDs in their off state; test_leds performs explicit safe tests.
for module in led-class-flash led-class-multicolor leds-qcom-lpg ledtrig-pattern leds-qcom-flash; do
	insmod "/lib/modules/${module}.ko" 2>/dev/null || true
done

# Display stack for fbcon/logo; failures must not kill the USB console.
/bin/load_display

while [ ! -e /dev/ttyGS0 ]; do
	sleep 1
done

stty -F /dev/ttyGS0 raw -echo
exec </dev/ttyGS0 >/dev/ttyGS0 2>&1
echo "OPPO R11T mainline Linux diagnostic shell"
echo "Helpers: test_keys | test_display | test_touch | test_gpu | test_wifi | test_bt | test_audio | test_battery | test_leds | test_usb_host"
uname -a
cat /sys/firmware/devicetree/base/model
echo
exec sh
