cat > /bin/test_leds << 'EOF'
#!/bin/busybox sh
for module in led-class-flash led-class-multicolor leds-qcom-lpg ledtrig-pattern leds-qcom-flash; do
	insmod "/lib/modules/${module}.ko" 2>/dev/null || true
done

STATUS_LED=""
FLASH_LED=""
for led in /sys/class/leds/*; do
	[ -d "$led" ] || continue
	case "${led##*/}" in
		*status*) STATUS_LED=$led ;;
	esac
	[ -e "$led/flash_strobe" ] && FLASH_LED=$led
done

show_led() {
	led=$1
	[ -n "$led" ] || return
	echo "--- ${led##*/} ---"
	for property in max_brightness brightness trigger flash_brightness \
		flash_timeout flash_strobe flash_fault; do
		[ -r "$led/$property" ] || continue
		printf "%s=" "$property"
		cat "$led/$property"
	done
}

case "${1:-status}" in
	status)
		show_led "$STATUS_LED"
		show_led "$FLASH_LED"
		;;
	breathe)
		[ -n "$STATUS_LED" ] || { echo "white status LED not found"; exit 1; }
		echo pattern > "$STATUS_LED/trigger" || exit 1
		echo -1 > "$STATUS_LED/repeat" || exit 1
		# Hardware LUT: about 3 mA peak, 0.4 s ramp, 0.7/2 s pauses.
		echo "0 2000 0 0 16 100 16 0 32 100 32 0 48 100 48 0 64 700 64 0 48 100 48 0 32 100 32 0 16 100 16 0 0 100 0 0" \
			> "$STATUS_LED/hw_pattern" || exit 1
		echo "breathing=${STATUS_LED##*/}"
		;;
	torch)
		[ -n "$FLASH_LED" ] || { echo "camera flash LED not found"; exit 1; }
		# 64/255 of the 100 mA DT limit is about 25 mA.
		echo 64 > "$FLASH_LED/brightness"
		sleep 2
		echo 0 > "$FLASH_LED/brightness"
		echo "torch_test=complete"
		;;
	flash)
		[ -n "$FLASH_LED" ] || { echo "camera flash LED not found"; exit 1; }
		echo 100000 > "$FLASH_LED/flash_brightness"
		echo 100000 > "$FLASH_LED/flash_timeout"
		echo 1 > "$FLASH_LED/flash_strobe"
		sleep 1
		echo 0 > "$FLASH_LED/flash_strobe" 2>/dev/null || true
		echo "flash_fault=$(cat "$FLASH_LED/flash_fault" 2>/dev/null)"
		;;
	off)
		if [ -n "$STATUS_LED" ]; then
			echo none > "$STATUS_LED/trigger"
			echo 0 > "$STATUS_LED/brightness"
		fi
		[ -n "$FLASH_LED" ] && echo 0 > "$FLASH_LED/brightness"
		echo "leds=off"
		;;
	*)
		echo "usage: test_leds [status|breathe|torch|flash|off]"
		exit 2
		;;
esac
EOF
chmod 0755 /bin/test_leds

cat > /bin/test_usb_host << 'EOF'
#!/bin/busybox sh
ROLE=""
for path in /sys/class/usb_role/*/role; do
	[ -e "$path" ] || continue
	ROLE=$path
	break
done

[ -n "$ROLE" ] || { echo "USB role switch not found"; exit 1; }

case "${1:-status}" in
	status)
		echo "role=$(cat "$ROLE")"
		for dev in /sys/bus/usb/devices/[0-9]*; do
			[ -d "$dev" ] || continue
			printf '%s' "${dev##*/}"
			[ -r "$dev/idVendor" ] && printf ' %s:%s' "$(cat "$dev/idVendor")" "$(cat "$dev/idProduct")"
			[ -r "$dev/product" ] && printf ' %s' "$(cat "$dev/product")"
			echo
		done
		;;
	start)
		[ "$$" -eq 1 ] || {
			echo "run from the main shell as: exec test_usb_host start"
			exit 1
		}
		[ "$(cat "$ROLE")" = "device" ] || {
			echo "USB must begin in device role"
			exit 1
		}
		UDC_FILE=/sys/kernel/config/usb_gadget/r11t/UDC
		[ -r "$UDC_FILE" ] || { echo "USB gadget UDC binding not found"; exit 1; }
		UDC=$(cat "$UDC_FILE")
		[ -n "$UDC" ] || { echo "USB gadget is not bound"; exit 1; }
		CACHE_DEV=""
		for uevent in /sys/class/block/mmcblk*p*/uevent; do
			[ -r "$uevent" ] || continue
			grep -q '^PARTNAME=cache$' "$uevent" || continue
			CACHE_DEV="/dev/$(basename "$(dirname "$uevent")")"
			break
		done
		[ -n "$CACHE_DEV" ] || { echo "cache partition not found"; exit 1; }
		mkdir -p /mnt/usb-host-cache /tmp
		mount -t ext4 "$CACHE_DEV" /mnt/usb-host-cache || exit 1
		LOG=/mnt/usb-host-cache/mainline-usb-host-result.log
		echo "Unplug the PC and connect the OTG device within 10 seconds"
		echo "Press keys for 15 seconds; the phone will reboot to Android"
		sleep 10

		# This script is PID 1. Close the ACM tty before unbinding its UDC.
		exec </dev/null >"$LOG" 2>&1
		echo "role_before=$(cat "$ROLE")"
		echo "" > "$UDC_FILE"
		sleep 2
		echo host > "$ROLE"
		sleep 3
		echo "role_host=$(cat "$ROLE")"
		found=0
		for i in $(seq 1 20); do
			for dev in /sys/bus/usb/devices/[0-9]-*; do
				[ -r "$dev/idVendor" ] || continue
				echo "usb_device=${dev##*/} vid=$(cat "$dev/idVendor") pid=$(cat "$dev/idProduct") product=$(cat "$dev/product" 2>/dev/null)"
				found=1
			done
			[ "$found" -eq 1 ] && break
			sleep 1
		done
		for block in /dev/sd?; do
			[ -b "$block" ] || continue
			echo "block_device=$block"
			dd if="$block" bs=4096 count=1 2>/dev/null | sha256sum
		done
		input_found=0
		for event_sysfs in /sys/class/input/event*; do
			[ -e "$event_sysfs/device" ] || continue
			case "$(readlink -f "$event_sysfs/device")" in
				*usb*) ;;
				*) continue ;;
			esac
			event="/dev/input/${event_sysfs##*/}"
			echo "usb_input=$event"
			timeout 10 dd if="$event" of=/tmp/usb-input-event.bin bs=24 count=1 2>/dev/null || true
			bytes=$(wc -c < /tmp/usb-input-event.bin)
			echo "input_bytes=$bytes"
			if [ "$bytes" -gt 0 ]; then
				sha256sum /tmp/usb-input-event.bin
				input_found=1
				break
			fi
		done
		echo "device_found=$found"
		echo "input_found=$input_found"
		echo "test_complete=1"
		sync
		exec >/dev/null 2>&1
		umount /mnt/usb-host-cache
		reboot -f
		;;
	result)
		echo "read /cache/mainline-usb-host-result.log from Android"
		;;
	*)
		echo "usage: test_usb_host [status|start|result]"
		echo "start must be invoked as: exec test_usb_host start"
		exit 2
		;;
esac
EOF
chmod 0755 /bin/test_usb_host

